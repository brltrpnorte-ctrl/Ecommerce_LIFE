APP_NAME=LIFE STYLE API
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGIN_REGEX=
ALLOWED_HOSTS=localhost,127.0.0.1
AUTH_TOKEN=REPLACE_WITH_STRONG_ADMIN_TOKEN
# Optional (rotation window): previous token(s), comma-separated
AUTH_TOKEN_PREVIOUS=
REQUEST_RATE_LIMIT_PER_MINUTE=180
SENSITIVE_RATE_LIMIT_PER_MINUTE=60
# Backend-only secrets (never commit real values)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY

# PostgreSQL / Supabase connection strings (backend only)
# Local Docker Postgres (development)
DATABASE_URL=postgresql://app_user:REPLACE_WITH_STRONG_PASSWORD@localhost:5432/app_db
# Supabase runtime on Vercel (serverless): use Transaction pooler :6543
# If Network Restrictions (allow_list) is enabled, add the backend egress IP(s).
DATABASE_URL_RUNTIME=postgresql://app_runtime:REPLACE_WITH_STRONG_PASSWORD@YOUR_POOLER_HOST:6543/postgres?sslmode=require
# Supabase migrations/admin tasks: use Direct connection :5432
# If local environment lacks IPv6 connectivity, use Session Pooler temporarily for migration execution.
DATABASE_URL_MIGRATIONS=postgresql://app_owner:REPLACE_WITH_STRONG_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
